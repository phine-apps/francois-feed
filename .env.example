# ============================================================
# francois-feed Environment Variables Template
# Copy this file and fill in your actual values:
#   cp .env.example .env
# NEVER commit your .env file — it contains sensitive secrets.
# ============================================================

# Google Gemini API key
# Obtain one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# (Optional) Gemini model for query planning and web search (Step 0 & 1)
# Defaults to "gemini-2.5-flash" if not set
# GEMINI_SEARCH_MODEL="gemini-2.5-flash"

# (Optional) Gemini model for RSS XML generation (Step 2)
# Defaults to "gemini-3.5-flash". Switch to "gemini-3.1-pro" for higher quality.
# GEMINI_GEN_MODEL="gemini-3.1-pro"

# (Legacy) Single model override — used as fallback when the above are not set
# GEMINI_MODEL="gemini-3.5-flash"

# (Optional) Set to "true" to fetch og:image from source URLs and embed
# <media:thumbnail> elements in each RSS item (adds several seconds of latency)
# ENABLE_MEDIA_THUMBNAILS="false"

# GitHub Personal Access Token (requires the "gist" scope)
# Generate one at: https://github.com/settings/tokens
GH_TOKEN="ghp_your_github_token_here"

# GitHub Gist ID
# The alphanumeric string at the end of your Gist URL
# e.g., https://gist.github.com/<user>/<GIST_ID>
GIST_ID="your_gist_id_here"

# RSS feed generation prompt
# Instructions passed to Gemini describing what content to generate.
# Example:
# RSS_CONFIG_PROMPT="
# Generate an RSS feed covering:
# 1. Global News: Top 3 international headlines (e.g., from Reuters or AP).
# 2. Tech Trends: Latest updates in Web Development and open-source projects.
# 3. Productivity: A practical tip for remote work or time management.
#
# Format: Use professional tone. Summaries should be 200-300 characters long.
# "
RSS_CONFIG_PROMPT="your_prompt_here"
